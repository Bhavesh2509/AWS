{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Contoso Startup Labs - AWS IAM Basics Lab | Windows Jump VM with pre-installed tools",
  "Parameters": {
    "InstanceType": {
      "Type": "String",
      "Default": "t3.micro",
      "AllowedValues": [
        "t2.micro",
        "t3.micro"
      ],
      "Description": "EC2 instance type for the Windows Jump VM. Only free-tier eligible types are allowed."
    },
    "WindowsAMIId": {
      "Type": "AWS::SSM::Parameter::Value<AWS::EC2::Image::Id>",
      "Default": "/aws/service/ami-windows-latest/Windows_Server-2022-English-Full-Base",
      "Description": "Windows Server 2022 AMI ID resolved from SSM Parameter Store for the deployment region."
    },
    "VpcCIDR": {
      "Type": "String",
      "Default": "10.0.0.0/16",
      "Description": "CIDR block for the Lab VPC."
    },
    "PublicSubnetCIDR": {
      "Type": "String",
      "Default": "10.0.1.0/24",
      "Description": "CIDR block for the public subnet."
    },
    "RDPAllowedCIDR": {
      "Type": "String",
      "Default": "0.0.0.0/0",
      "Description": "CIDR range allowed to reach the VM over RDP/HTTPS. Restrict to CloudLabs IP range in production."
    },
    "AllowedRouteCIDR": {
      "Type": "String",
      "Default": "0.0.0.0/0",
      "Description": "Destination CIDR for the public route to the Internet Gateway. Override with the CloudLabs egress IP range (e.g. 203.0.113.0/24) to satisfy NO_UNRESTRICTED_ROUTE_TO_IGW. Must not be 0.0.0.0/0 in production.",
      "AllowedPattern": "^(([0-9]{1,3}\\.){3}[0-9]{1,3}/([0-9]|[1-2][0-9]|3[0-2]))$",
      "ConstraintDescription": "Must be a valid CIDR block (e.g. 203.0.113.0/24). Do not use 0.0.0.0/0 in production."
    },
    "VMAdminUsername": {
      "Type": "String",
      "Default": "LabAdmin",
      "Description": "Local administrator username for the Windows VM."
    },
    "VMAdminPasswordSSMPath": {
      "Type": "String",
      "Default": "/cloudlabs/lab/vm-admin-password",
      "Description": "SSM Parameter Store path (SecureString) where CloudLabs pre-stores the Windows VM admin password. Resolved at deploy time via dynamic reference."
    },
    "LabUserTag": {
      "Type": "String",
      "Default": "lab-user",
      "Description": "Tag value used to identify all resources belonging to this lab deployment."
    },
    "LabIAMConsoleUsername": {
      "Type": "String",
      "Default": "lab-student",
      "Description": "IAM username that developers use to log into the AWS Console."
    },
    "LabIAMConsolePasswordSSMPath": {
      "Type": "String",
      "Default": "/cloudlabs/lab/iam-console-password",
      "Description": "SSM Parameter Store path (SecureString) where CloudLabs pre-stores the IAM console user password. Resolved at deploy time via dynamic reference."
    }
  },
  "Resources": {
    "LabPermissionBoundary": {
      "Type": "AWS::IAM::ManagedPolicy",
      "Properties": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "BoundaryAllowEC2FreeTierOnly",
              "Effect": "Allow",
              "Action": [
                "ec2:RunInstances",
                "ec2:StopInstances",
                "ec2:StartInstances",
                "ec2:TerminateInstances",
                "ec2:RebootInstances",
                "ec2:CreateKeyPair",
                "ec2:DeleteKeyPair",
                "ec2:ImportKeyPair",
                "ec2:CreateSecurityGroup",
                "ec2:DeleteSecurityGroup",
                "ec2:AuthorizeSecurityGroupIngress",
                "ec2:AuthorizeSecurityGroupEgress",
                "ec2:RevokeSecurityGroupIngress",
                "ec2:RevokeSecurityGroupEgress",
                "ec2:CreateTags",
                "ec2:DeleteTags"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "ec2:InstanceType": [
                    "t2.micro",
                    "t3.micro"
                  ]
                }
              }
            },
            {
              "Sid": "BoundaryAllowEC2DescribeUnconditional",
              "Effect": "Allow",
              "Action": [
                "ec2:DescribeInstances",
                "ec2:DescribeInstanceStatus",
                "ec2:DescribeInstanceTypes",
                "ec2:DescribeImages",
                "ec2:DescribeKeyPairs",
                "ec2:DescribeSecurityGroups",
                "ec2:DescribeSecurityGroupRules",
                "ec2:DescribeVpcs",
                "ec2:DescribeSubnets",
                "ec2:DescribeRouteTables",
                "ec2:DescribeInternetGateways",
                "ec2:DescribeAvailabilityZones",
                "ec2:DescribeRegions",
                "ec2:DescribeTags",
                "ec2:DescribeVolumes",
                "ec2:DescribeNetworkInterfaces",
                "ec2:DescribeAddresses",
                "ec2:DescribeLaunchTemplates",
                "ec2:DescribeLaunchTemplateVersions"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryAllowIAMScopedToLabOnly",
              "Effect": "Allow",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:PassRole",
                "iam:TagRole",
                "iam:UntagRole",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreateInstanceProfile",
                "iam:DeleteInstanceProfile",
                "iam:AddRoleToInstanceProfile",
                "iam:RemoveRoleFromInstanceProfile",
                "iam:ChangePassword",
                "iam:GetLoginProfile",
                "iam:CreateAccessKey",
                "iam:DeleteAccessKey",
                "iam:UpdateAccessKey"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "iam:PermissionsBoundary": {
                    "Ref": "LabPermissionBoundary"
                  }
                }
              }
            },
            {
              "Sid": "BoundaryAllowIAMReadAlways",
              "Effect": "Allow",
              "Action": [
                "iam:GetRole",
                "iam:ListRoles",
                "iam:GetPolicy",
                "iam:GetPolicyVersion",
                "iam:ListPolicies",
                "iam:ListPolicyVersions",
                "iam:ListEntitiesForPolicy",
                "iam:GetRolePolicy",
                "iam:ListRolePolicies",
                "iam:ListAttachedRolePolicies",
                "iam:GetInstanceProfile",
                "iam:ListInstanceProfiles",
                "iam:ListInstanceProfilesForRole",
                "iam:GetUser",
                "iam:ListUsers",
                "iam:GetGroup",
                "iam:ListGroups",
                "iam:GetUserPolicy",
                "iam:ListUserPolicies",
                "iam:ListAttachedUserPolicies",
                "iam:ListGroupsForUser",
                "iam:ListAccessKeys",
                "iam:GetAccessKeyLastUsed",
                "iam:GetAccountSummary",
                "iam:GetAccountPasswordPolicy",
                "iam:GetCredentialReport",
                "iam:GenerateCredentialReport",
                "iam:SimulatePrincipalPolicy",
                "iam:SimulateCustomPolicy"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryAllowS3Basic",
              "Effect": "Allow",
              "Action": [
                "s3:ListAllMyBuckets",
                "s3:GetBucketLocation",
                "s3:ListBucket",
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:CreateBucket",
                "s3:DeleteBucket",
                "s3:GetBucketPolicy",
                "s3:PutBucketPolicy",
                "s3:GetBucketAcl",
                "s3:PutBucketAcl"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryAllowSupportingServices",
              "Effect": "Allow",
              "Action": [
                "cloudwatch:GetMetricData",
                "cloudwatch:GetMetricStatistics",
                "cloudwatch:ListMetrics",
                "cloudwatch:DescribeAlarms",
                "logs:DescribeLogGroups",
                "logs:DescribeLogStreams",
                "logs:GetLogEvents",
                "logs:FilterLogEvents",
                "sts:GetCallerIdentity",
                "sts:AssumeRole",
                "ssm:DescribeInstanceInformation",
                "ssm:GetDocument",
                "ssm:ListInstanceAssociations",
                "ssm:UpdateInstanceInformation",
                "ssm:UpdateInstanceAssociationStatus",
                "ec2messages:GetMessages",
                "ec2messages:SendReply",
                "ec2messages:AcknowledgeMessage",
                "ssmmessages:CreateControlChannel",
                "ssmmessages:CreateDataChannel",
                "ssmmessages:OpenControlChannel",
                "ssmmessages:OpenDataChannel"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryDenyIAMUserAndGroupMutation",
              "Effect": "Deny",
              "Action": [
                "iam:CreateUser",
                "iam:DeleteUser",
                "iam:UpdateUser",
                "iam:CreateLoginProfile",
                "iam:DeleteLoginProfile",
                "iam:AddUserToGroup",
                "iam:RemoveUserFromGroup",
                "iam:CreateGroup",
                "iam:DeleteGroup",
                "iam:UpdateGroup",
                "iam:AttachUserPolicy",
                "iam:DetachUserPolicy",
                "iam:PutUserPolicy",
                "iam:DeleteUserPolicy",
                "iam:AttachGroupPolicy",
                "iam:DetachGroupPolicy",
                "iam:PutGroupPolicy",
                "iam:DeleteGroupPolicy",
                "iam:UpdateAssumeRolePolicy"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryDenyBoundaryTampering",
              "Effect": "Deny",
              "Action": [
                "iam:DeleteRolePermissionsBoundary",
                "iam:DeleteUserPermissionsBoundary",
                "iam:PutRolePermissionsBoundary",
                "iam:PutUserPermissionsBoundary"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryDenyBillingAndOrg",
              "Effect": "Deny",
              "Action": [
                "organizations:*",
                "account:*",
                "billing:*",
                "budgets:*",
                "ce:*",
                "cur:*",
                "aws-portal:*",
                "purchase-orders:*",
                "savingsplans:*",
                "reservations:*"
              ],
              "Resource": "*"
            }
          ]
        }
      }
    },
    "LabStudentPolicy": {
      "Type": "AWS::IAM::ManagedPolicy",
      "DependsOn": "LabPermissionBoundary",
      "Properties": {
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "AllowEC2FreeTierOnly",
              "Effect": "Allow",
              "Action": [
                "ec2:RunInstances",
                "ec2:StopInstances",
                "ec2:StartInstances",
                "ec2:TerminateInstances",
                "ec2:RebootInstances",
                "ec2:CreateKeyPair",
                "ec2:DeleteKeyPair",
                "ec2:ImportKeyPair",
                "ec2:CreateSecurityGroup",
                "ec2:DeleteSecurityGroup",
                "ec2:AuthorizeSecurityGroupIngress",
                "ec2:AuthorizeSecurityGroupEgress",
                "ec2:RevokeSecurityGroupIngress",
                "ec2:RevokeSecurityGroupEgress",
                "ec2:CreateTags",
                "ec2:DeleteTags"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "ec2:InstanceType": [
                    "t2.micro",
                    "t3.micro"
                  ]
                }
              }
            },
            {
              "Sid": "AllowEC2DescribeUnconditional",
              "Effect": "Allow",
              "Action": [
                "ec2:DescribeInstances",
                "ec2:DescribeInstanceStatus",
                "ec2:DescribeInstanceTypes",
                "ec2:DescribeImages",
                "ec2:DescribeKeyPairs",
                "ec2:DescribeSecurityGroups",
                "ec2:DescribeSecurityGroupRules",
                "ec2:DescribeVpcs",
                "ec2:DescribeSubnets",
                "ec2:DescribeRouteTables",
                "ec2:DescribeInternetGateways",
                "ec2:DescribeAvailabilityZones",
                "ec2:DescribeRegions",
                "ec2:DescribeTags",
                "ec2:DescribeVolumes",
                "ec2:DescribeNetworkInterfaces",
                "ec2:DescribeAddresses",
                "ec2:DescribeLaunchTemplates",
                "ec2:DescribeLaunchTemplateVersions"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowIAMRoleAndPolicyManagement",
              "Effect": "Allow",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:PassRole",
                "iam:TagRole",
                "iam:UntagRole",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreateInstanceProfile",
                "iam:DeleteInstanceProfile",
                "iam:AddRoleToInstanceProfile",
                "iam:RemoveRoleFromInstanceProfile"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "iam:PermissionsBoundary": {
                    "Ref": "LabPermissionBoundary"
                  }
                }
              }
            },
            {
              "Sid": "AllowIAMReadAlways",
              "Effect": "Allow",
              "Action": [
                "iam:GetRole",
                "iam:ListRoles",
                "iam:GetPolicy",
                "iam:GetPolicyVersion",
                "iam:ListPolicies",
                "iam:ListPolicyVersions",
                "iam:ListEntitiesForPolicy",
                "iam:GetRolePolicy",
                "iam:ListRolePolicies",
                "iam:ListAttachedRolePolicies",
                "iam:GetInstanceProfile",
                "iam:ListInstanceProfiles",
                "iam:ListInstanceProfilesForRole",
                "iam:GetUser",
                "iam:ListUsers",
                "iam:GetGroup",
                "iam:ListGroups",
                "iam:GetUserPolicy",
                "iam:ListUserPolicies",
                "iam:ListAttachedUserPolicies",
                "iam:ListGroupsForUser",
                "iam:GetAccountSummary",
                "iam:GetAccountPasswordPolicy",
                "iam:GetCredentialReport",
                "iam:GenerateCredentialReport",
                "iam:SimulatePrincipalPolicy",
                "iam:SimulateCustomPolicy"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowSelfCredentialManagement",
              "Effect": "Allow",
              "Action": [
                "iam:ChangePassword",
                "iam:GetLoginProfile",
                "iam:UpdateLoginProfile",
                "iam:CreateAccessKey",
                "iam:DeleteAccessKey",
                "iam:ListAccessKeys",
                "iam:UpdateAccessKey",
                "iam:GetAccessKeyLastUsed"
              ],
              "Resource": {
                "Fn::Sub": "arn:${AWS::Partition}:iam::${AWS::AccountId}:user/${LabIAMConsoleUsername}"
              }
            },
            {
              "Sid": "DenyIAMUserAndGroupMutation",
              "Effect": "Deny",
              "Action": [
                "iam:CreateUser",
                "iam:DeleteUser",
                "iam:UpdateUser",
                "iam:CreateLoginProfile",
                "iam:DeleteLoginProfile",
                "iam:AddUserToGroup",
                "iam:RemoveUserFromGroup",
                "iam:CreateGroup",
                "iam:DeleteGroup",
                "iam:UpdateGroup",
                "iam:AttachUserPolicy",
                "iam:DetachUserPolicy",
                "iam:PutUserPolicy",
                "iam:DeleteUserPolicy",
                "iam:AttachGroupPolicy",
                "iam:DetachGroupPolicy",
                "iam:PutGroupPolicy",
                "iam:DeleteGroupPolicy"
              ],
              "Resource": "*"
            },
            {
              "Sid": "DenyBoundaryTampering",
              "Effect": "Deny",
              "Action": [
                "iam:DeleteRolePermissionsBoundary",
                "iam:DeleteUserPermissionsBoundary",
                "iam:PutRolePermissionsBoundary",
                "iam:PutUserPermissionsBoundary"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowS3LabAccess",
              "Effect": "Allow",
              "Action": [
                "s3:ListAllMyBuckets",
                "s3:GetBucketLocation",
                "s3:ListBucket",
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:CreateBucket",
                "s3:DeleteBucket",
                "s3:GetBucketPolicy",
                "s3:PutBucketPolicy",
                "s3:GetBucketAcl",
                "s3:PutBucketAcl"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowCloudWatchAndLogs",
              "Effect": "Allow",
              "Action": [
                "cloudwatch:GetMetricData",
                "cloudwatch:GetMetricStatistics",
                "cloudwatch:ListMetrics",
                "cloudwatch:DescribeAlarms",
                "logs:DescribeLogGroups",
                "logs:DescribeLogStreams",
                "logs:GetLogEvents",
                "logs:FilterLogEvents"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowSTSForRoleAssumption",
              "Effect": "Allow",
              "Action": [
                "sts:GetCallerIdentity",
                "sts:AssumeRole"
              ],
              "Resource": "*"
            },
            {
              "Sid": "DenyBillingAndOrg",
              "Effect": "Deny",
              "Action": [
                "organizations:*",
                "account:*",
                "billing:*",
                "budgets:*",
                "ce:*",
                "cur:*",
                "aws-portal:*",
                "purchase-orders:*",
                "savingsplans:*",
                "reservations:*"
              ],
              "Resource": "*"
            }
          ]
        }
      }
    },
    "LabConsoleUser": {
      "Type": "AWS::IAM::User",
      "DependsOn": [
        "LabPermissionBoundary",
        "LabStudentPolicy"
      ],
      "Properties": {
        "UserName": {
          "Ref": "LabIAMConsoleUsername"
        },
        "LoginProfile": {
          "Password": {
            "Fn::Sub": "{{resolve:ssm-secure:${LabIAMConsolePasswordSSMPath}}}"
          },
          "PasswordResetRequired": false
        },
        "PermissionsBoundary": {
          "Ref": "LabPermissionBoundary"
        },
        "ManagedPolicyArns": [
          {
            "Ref": "LabStudentPolicy"
          }
        ]
      }
    },
    "LabIAMRole": {
      "Type": "AWS::IAM::Role",
      "DependsOn": "LabPermissionBoundary",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "PermissionsBoundary": {
          "Ref": "LabPermissionBoundary"
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess",
          "arn:aws:iam::aws:policy/CloudWatchAgentServerPolicy",
          "arn:aws:iam::aws:policy/AmazonSSMManagedInstanceCore"
        ]
      }
    },
    "LabInstanceProfile": {
      "Type": "AWS::IAM::InstanceProfile",
      "Properties": {
        "Roles": [
          {
            "Ref": "LabIAMRole"
          }
        ]
      }
    },
    "LabVPC": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": {
          "Ref": "VpcCIDR"
        },
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true,
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabVPC"
          },
          {
            "Key": "CloudLabs",
            "Value": {
              "Ref": "LabUserTag"
            }
          }
        ]
      }
    },
    "InternetGateway": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabIGW"
          },
          {
            "Key": "CloudLabs",
            "Value": {
              "Ref": "LabUserTag"
            }
          }
        ]
      }
    },
    "AttachGateway": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": {
          "Ref": "LabVPC"
        },
        "InternetGatewayId": {
          "Ref": "InternetGateway"
        }
      }
    },
    "PublicSubnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": {
          "Ref": "LabVPC"
        },
        "CidrBlock": {
          "Ref": "PublicSubnetCIDR"
        },
        "AvailabilityZone": {
          "Fn::Select": [
            0,
            {
              "Fn::GetAZs": ""
            }
          ]
        },
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabPublicSubnet"
          },
          {
            "Key": "CloudLabs",
            "Value": {
              "Ref": "LabUserTag"
            }
          }
        ]
      }
    },
    "PublicRouteTable": {
      "Type": "AWS::EC2::RouteTable",
      "Properties": {
        "VpcId": {
          "Ref": "LabVPC"
        },
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabPublicRT"
          },
          {
            "Key": "CloudLabs",
            "Value": {
              "Ref": "LabUserTag"
            }
          }
        ]
      }
    },
    "PublicRoute": {
      "Type": "AWS::EC2::Route",
      "DependsOn": "AttachGateway",
      "Properties": {
        "RouteTableId": {
          "Ref": "PublicRouteTable"
        },
        "DestinationCidrBlock": {
          "Ref": "AllowedRouteCIDR"
        },
        "GatewayId": {
          "Ref": "InternetGateway"
        }
      }
    },
    "SubnetRouteTableAssociation": {
      "Type": "AWS::EC2::SubnetRouteTableAssociation",
      "Properties": {
        "SubnetId": {
          "Ref": "PublicSubnet"
        },
        "RouteTableId": {
          "Ref": "PublicRouteTable"
        }
      }
    },
    "LabSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Security group for IAM Lab Windows Jump VM - allows RDP and HTTPS",
        "VpcId": {
          "Ref": "LabVPC"
        },
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3389,
            "ToPort": 3389,
            "CidrIp": {
              "Ref": "RDPAllowedCIDR"
            },
            "Description": "RDP access for CloudLabs EC2 over HTTP feature"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": {
              "Ref": "RDPAllowedCIDR"
            },
            "Description": "HTTPS for browser-based RDP via CloudLabs"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": {
              "Ref": "RDPAllowedCIDR"
            },
            "Description": "HTTP for CloudLabs EC2 access over HTTP feature"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "CidrIp": "0.0.0.0/0",
            "Description": "Allow all outbound traffic"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabSG"
          },
          {
            "Key": "CloudLabs",
            "Value": {
              "Ref": "LabUserTag"
            }
          }
        ]
      }
    },
    "LabWindowsVM": {
      "Type": "AWS::EC2::Instance",
      "DependsOn": [
        "LabInstanceProfile",
        "LabPermissionBoundary",
        "LabConsoleUser",
        "AttachGateway"
      ],
      "CreationPolicy": {
        "ResourceSignal": {
          "Timeout": "PT30M"
        }
      },
      "Properties": {
        "IamInstanceProfile": {
          "Ref": "LabInstanceProfile"
        },
        "ImageId": {
          "Ref": "WindowsAMIId"
        },
        "InstanceType": {
          "Ref": "InstanceType"
        },
        "SubnetId": {
          "Ref": "PublicSubnet"
        },
        "SecurityGroupIds": [
          {
            "Ref": "LabSecurityGroup"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabJumpVM"
          },
          {
            "Key": "CloudLabs",
            "Value": {
              "Ref": "LabUserTag"
            }
          },
          {
            "Key": "Lab",
            "Value": "IAMBasics"
          }
        ],
        "UserData": {
          "Fn::Base64": {
            "Fn::Sub": [
              "<powershell>\n$LogFile = \"C:\\cfn-bootstrap.log\"\nfunction Write-Log { param($msg) $ts = Get-Date -Format 'yyyy-MM-dd HH:mm:ss'; \"$ts  $msg\" | Tee-Object -FilePath $LogFile -Append | Write-Host }\nWrite-Log \"Bootstrap started\"\n\n# 1. Create / update local admin account\ntry {\n    $Username = \"${VMAdminUsername}\"\n    $Password = ConvertTo-SecureString \"${VMAdminPasswordValue}\" -AsPlainText -Force\n    if (Get-LocalUser -Name $Username -ErrorAction SilentlyContinue) {\n        Set-LocalUser -Name $Username -Password $Password\n        Write-Log \"Updated existing user $Username\"\n    } else {\n        New-LocalUser -Name $Username -Password $Password -FullName \"Lab Administrator\" -Description \"CloudLabs Jump VM admin\" -PasswordNeverExpires\n        Add-LocalGroupMember -Group \"Administrators\" -Member $Username\n        Write-Log \"Created user $Username\"\n    }\n} catch { Write-Log \"ERROR creating user: $_\" }\n\n# 2. Enable RDP\ntry {\n    Set-ItemProperty -Path \"HKLM:\\System\\CurrentControlSet\\Control\\Terminal Server\" -Name \"fDenyTSConnections\" -Value 0\n    Set-ItemProperty -Path \"HKLM:\\System\\CurrentControlSet\\Control\\Terminal Server\\WinStations\\RDP-Tcp\" -Name \"UserAuthentication\" -Value 0\n    Set-ItemProperty -Path \"HKLM:\\System\\CurrentControlSet\\Control\\Lsa\" -Name \"LimitBlankPasswordUse\" -Value 0\n    Enable-NetFirewallRule -DisplayGroup \"Remote Desktop\"\n    Write-Log \"RDP enabled\"\n} catch { Write-Log \"ERROR enabling RDP: $_\" }\n\n# 3. Install cfn-bootstrap if missing\n$CfnSignal = \"C:\\Program Files\\Amazon\\cfn-bootstrap\\cfn-signal.exe\"\nif (-not (Test-Path $CfnSignal)) {\n    Write-Log \"cfn-bootstrap not found, installing...\"\n    try {\n        Invoke-WebRequest -Uri \"https://s3.amazonaws.com/cloudformation-examples/aws-cfn-bootstrap-py3-win64-latest.exe\" -OutFile \"C:\\cfn-bootstrap.exe\" -UseBasicParsing\n        Start-Process \"C:\\cfn-bootstrap.exe\" -ArgumentList \"/install /quiet /norestart\" -Wait\n        Remove-Item \"C:\\cfn-bootstrap.exe\" -Force -ErrorAction SilentlyContinue\n        Write-Log \"cfn-bootstrap installed\"\n    } catch { Write-Log \"ERROR installing cfn-bootstrap: $_\" }\n} else {\n    Write-Log \"cfn-bootstrap already present\"\n}\n\n# 4. Install AWS CLI v2\ntry {\n    Invoke-WebRequest -Uri \"https://awscli.amazonaws.com/AWSCLIV2.msi\" -OutFile \"C:\\AWSCLIV2.msi\" -UseBasicParsing\n    Start-Process msiexec.exe -ArgumentList \"/i C:\\AWSCLIV2.msi /quiet /norestart\" -Wait\n    Remove-Item \"C:\\AWSCLIV2.msi\" -Force -ErrorAction SilentlyContinue\n    Write-Log \"AWS CLI installed\"\n} catch { Write-Log \"ERROR installing AWS CLI: $_\" }\n\n# 5. Install Google Chrome\ntry {\n    Invoke-WebRequest -Uri \"https://dl.google.com/chrome/install/latest/chrome_installer.exe\" -OutFile \"C:\\chrome_installer.exe\" -UseBasicParsing\n    Start-Process \"C:\\chrome_installer.exe\" -ArgumentList \"/silent /install\" -Wait\n    Remove-Item \"C:\\chrome_installer.exe\" -Force -ErrorAction SilentlyContinue\n    Write-Log \"Chrome installed\"\n} catch { Write-Log \"ERROR installing Chrome: $_\" }\n\n# 6. Desktop shortcut to AWS Console\ntry {\n    $WshShell = New-Object -ComObject WScript.Shell\n    $Shortcut = $WshShell.CreateShortcut(\"C:\\Users\\Public\\Desktop\\AWS Console.lnk\")\n    $Shortcut.TargetPath = \"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\"\n    $Shortcut.Arguments = \"https://${AWS::AccountId}.signin.aws.amazon.com/console\"\n    $Shortcut.Description = \"Open AWS Console\"\n    $Shortcut.Save()\n    Write-Log \"Desktop shortcut created\"\n} catch { Write-Log \"ERROR creating shortcut: $_\" }\n\n# 7. README on Desktop\ntry {\n    $readme = @\"\nAWS IAM Basics Lab - Contoso Startup Labs\n==========================================\n\nAWS CONSOLE LOGIN\n  URL      : https://${AWS::AccountId}.signin.aws.amazon.com/console\n  Username : ${LabIAMConsoleUsername}\n  Password : ** See your CloudLabs environment page **\n\nRDP LOGIN (this machine)\n  Username : ${VMAdminUsername}\n  Password : ** See your CloudLabs environment page **\n\nRESTRICTIONS\n  - EC2 : only t2.micro and t3.micro instance types are allowed\n  - IAM : creating users or modifying user/group policies is blocked\n  - IAM : all roles you create MUST have LabPermissionBoundary attached\n\nTOOLS PRE-INSTALLED\n  - AWS CLI v2   (open PowerShell and run: aws --version)\n  - Google Chrome\n\nFollow the lab guide shown in your CloudLabs browser tab.\n\"@\n    Set-Content -Path \"C:\\Users\\Public\\Desktop\\README.txt\" -Value $readme -Encoding UTF8\n    Write-Log \"README created\"\n} catch { Write-Log \"ERROR creating README: $_\" }\n\n# 8. Signal CloudFormation -- always runs regardless of above errors\nWrite-Log \"Sending cfn-signal...\"\n$CfnSignal = \"C:\\Program Files\\Amazon\\cfn-bootstrap\\cfn-signal.exe\"\nif (Test-Path $CfnSignal) {\n    & $CfnSignal --exit-code 0 --stack \"${AWS::StackName}\" --resource LabWindowsVM --region \"${AWS::Region}\"\n    Write-Log \"cfn-signal sent successfully\"\n} else {\n    Write-Log \"cfn-signal.exe not found, trying CLI fallback...\"\n    try {\n        $InstanceId = (Invoke-RestMethod -Uri \"http://169.254.169.254/latest/meta-data/instance-id\" -UseBasicParsing)\n        aws cloudformation signal-resource --stack-name \"${AWS::StackName}\" --logical-resource-id LabWindowsVM --unique-id $InstanceId --status SUCCESS --region \"${AWS::Region}\"\n        Write-Log \"CLI signal sent\"\n    } catch { Write-Log \"ERROR sending signal via CLI: $_\" }\n}\nWrite-Log \"Bootstrap complete\"\n</powershell>\n<persist>true</persist>\n",
              {
                "VMAdminPasswordValue": "{{resolve:ssm-secure:${VMAdminPasswordSSMPath}}}"
              }
            ]
          }
        }
      }
    }
  },
  "Outputs": {
    "LabConsoleLoginURL": {
      "Description": "AWS Console sign-in URL \u2014 shown on CloudLabs environment page",
      "Value": {
        "Fn::Sub": "https://${AWS::AccountId}.signin.aws.amazon.com/console"
      }
    },
    "LabConsoleUsername": {
      "Description": "IAM username for AWS Console login",
      "Value": {
