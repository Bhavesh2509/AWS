{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Contoso Startup Labs - AWS IAM Basics Lab | Windows Jump VM with pre-installed tools",
  "Parameters": {
    "InstanceType": {
      "Type": "String",
      "Default": "t3.micro",
      "AllowedValues": [
        "t2.micro",
        "t3.micro"
      ],
      "Description": "EC2 instance type for the Windows Jump VM. Only free-tier eligible types are allowed."
    },
    "WindowsAMIId": {
      "Type": "AWS::SSM::Parameter::Value<AWS::EC2::Image::Id>",
      "Default": "/aws/service/ami-windows-latest/Windows_Server-2022-English-Full-Base",
      "Description": "Windows Server 2022 AMI ID resolved from SSM Parameter Store for the deployment region."
    },
    "VpcCIDR": {
      "Type": "String",
      "Default": "10.0.0.0/16",
      "Description": "CIDR block for the Lab VPC."
    },
    "PublicSubnetCIDR": {
      "Type": "String",
      "Default": "10.0.1.0/24",
      "Description": "CIDR block for the public subnet."
    },
    "RDPAllowedCIDR": {
      "Type": "String",
      "Default": "0.0.0.0/0",
      "Description": "CIDR range allowed to reach the VM over RDP/HTTPS. Restrict to CloudLabs IP range in production."
    },
    "VMAdminUsername": {
      "Type": "String",
      "Default": "LabAdmin",
      "Description": "Local administrator username for the Windows VM."
    },
    "VMAdminPassword": {
      "Type": "String",
      "NoEcho": true,
      "MinLength": 12,
      "MaxLength": 64,
      "Description": "Local administrator password for the Windows VM (RDP login). CloudLabs injects this automatically per deployment.",
      "ConstraintDescription": "Must be at least 12 characters long."
    },
    "LabUserTag": {
      "Type": "String",
      "Default": "lab-user",
      "Description": "Tag value used to identify all resources belonging to this lab deployment."
    },
    "LabIAMConsoleUsername": {
      "Type": "String",
      "Default": "lab-student",
      "Description": "IAM username that developers use to log into the AWS Console."
    },
    "LabIAMConsolePassword": {
      "Type": "String",
      "NoEcho": true,
      "MinLength": 12,
      "MaxLength": 64,
      "Description": "Console login password for the lab IAM user. CloudLabs injects this automatically per deployment. Must include uppercase, lowercase, a number, and a special character.",
      "ConstraintDescription": "Must be at least 12 characters and meet AWS password complexity requirements."
    }
  },
  "Resources": {
    "LabPermissionBoundary": {
      "Type": "AWS::IAM::ManagedPolicy",
      "Properties": {
        "ManagedPolicyName": "LabPermissionBoundary",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "BoundaryAllowEC2FreeTierOnly",
              "Effect": "Allow",
              "Action": [
                "ec2:RunInstances",
                "ec2:StopInstances",
                "ec2:StartInstances",
                "ec2:TerminateInstances",
                "ec2:RebootInstances",
                "ec2:CreateKeyPair",
                "ec2:DeleteKeyPair",
                "ec2:ImportKeyPair",
                "ec2:CreateSecurityGroup",
                "ec2:DeleteSecurityGroup",
                "ec2:AuthorizeSecurityGroupIngress",
                "ec2:AuthorizeSecurityGroupEgress",
                "ec2:RevokeSecurityGroupIngress",
                "ec2:RevokeSecurityGroupEgress",
                "ec2:CreateTags",
                "ec2:DeleteTags"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "ec2:InstanceType": [
                    "t2.micro",
                    "t3.micro"
                  ]
                }
              }
            },
            {
              "Sid": "BoundaryAllowEC2DescribeUnconditional",
              "Effect": "Allow",
              "Action": [
                "ec2:DescribeInstances",
                "ec2:DescribeInstanceStatus",
                "ec2:DescribeInstanceTypes",
                "ec2:DescribeImages",
                "ec2:DescribeKeyPairs",
                "ec2:DescribeSecurityGroups",
                "ec2:DescribeSecurityGroupRules",
                "ec2:DescribeVpcs",
                "ec2:DescribeSubnets",
                "ec2:DescribeRouteTables",
                "ec2:DescribeInternetGateways",
                "ec2:DescribeAvailabilityZones",
                "ec2:DescribeRegions",
                "ec2:DescribeTags",
                "ec2:DescribeVolumes",
                "ec2:DescribeNetworkInterfaces",
                "ec2:DescribeAddresses",
                "ec2:DescribeLaunchTemplates",
                "ec2:DescribeLaunchTemplateVersions"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryAllowIAMScopedToLabOnly",
              "Effect": "Allow",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:PassRole",
                "iam:TagRole",
                "iam:UntagRole",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreateInstanceProfile",
                "iam:DeleteInstanceProfile",
                "iam:AddRoleToInstanceProfile",
                "iam:RemoveRoleFromInstanceProfile",
                "iam:ChangePassword",
                "iam:GetLoginProfile",
                "iam:CreateAccessKey",
                "iam:DeleteAccessKey",
                "iam:UpdateAccessKey"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "iam:PermissionsBoundary": "arn:aws:iam::${AWS::AccountId}:policy/LabPermissionBoundary"
                }
              }
            },
            {
              "Sid": "BoundaryAllowIAMReadAlways",
              "Effect": "Allow",
              "Action": [
                "iam:GetRole",
                "iam:ListRoles",
                "iam:GetPolicy",
                "iam:GetPolicyVersion",
                "iam:ListPolicies",
                "iam:ListPolicyVersions",
                "iam:ListEntitiesForPolicy",
                "iam:GetRolePolicy",
                "iam:ListRolePolicies",
                "iam:ListAttachedRolePolicies",
                "iam:GetInstanceProfile",
                "iam:ListInstanceProfiles",
                "iam:ListInstanceProfilesForRole",
                "iam:GetUser",
                "iam:ListUsers",
                "iam:GetGroup",
                "iam:ListGroups",
                "iam:GetUserPolicy",
                "iam:ListUserPolicies",
                "iam:ListAttachedUserPolicies",
                "iam:ListGroupsForUser",
                "iam:ListAccessKeys",
                "iam:GetAccessKeyLastUsed",
                "iam:GetAccountSummary",
                "iam:GetAccountPasswordPolicy",
                "iam:GetCredentialReport",
                "iam:GenerateCredentialReport",
                "iam:SimulatePrincipalPolicy",
                "iam:SimulateCustomPolicy"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryAllowS3Basic",
              "Effect": "Allow",
              "Action": [
                "s3:ListAllMyBuckets",
                "s3:GetBucketLocation",
                "s3:ListBucket",
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:CreateBucket",
                "s3:DeleteBucket",
                "s3:GetBucketPolicy",
                "s3:PutBucketPolicy",
                "s3:GetBucketAcl",
                "s3:PutBucketAcl"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryAllowSupportingServices",
              "Effect": "Allow",
              "Action": [
                "cloudwatch:GetMetricData",
                "cloudwatch:GetMetricStatistics",
                "cloudwatch:ListMetrics",
                "cloudwatch:DescribeAlarms",
                "logs:DescribeLogGroups",
                "logs:DescribeLogStreams",
                "logs:GetLogEvents",
                "logs:FilterLogEvents",
                "sts:GetCallerIdentity",
                "sts:AssumeRole"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryDenyIAMUserAndGroupMutation",
              "Effect": "Deny",
              "Action": [
                "iam:CreateUser",
                "iam:DeleteUser",
                "iam:UpdateUser",
                "iam:CreateLoginProfile",
                "iam:DeleteLoginProfile",
                "iam:AddUserToGroup",
                "iam:RemoveUserFromGroup",
                "iam:CreateGroup",
                "iam:DeleteGroup",
                "iam:UpdateGroup",
                "iam:AttachUserPolicy",
                "iam:DetachUserPolicy",
                "iam:PutUserPolicy",
                "iam:DeleteUserPolicy",
                "iam:AttachGroupPolicy",
                "iam:DetachGroupPolicy",
                "iam:PutGroupPolicy",
                "iam:DeleteGroupPolicy",
                "iam:UpdateAssumeRolePolicy"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryDenyBoundaryTampering",
              "Effect": "Deny",
              "Action": [
                "iam:DeleteRolePermissionsBoundary",
                "iam:DeleteUserPermissionsBoundary",
                "iam:PutRolePermissionsBoundary",
                "iam:PutUserPermissionsBoundary"
              ],
              "Resource": "*"
            },
            {
              "Sid": "BoundaryDenyBillingAndOrg",
              "Effect": "Deny",
              "Action": [
                "organizations:*",
                "account:*",
                "billing:*",
                "budgets:*",
                "ce:*",
                "cur:*",
                "aws-portal:*",
                "purchase-orders:*",
                "savingsplans:*",
                "reservations:*"
              ],
              "Resource": "*"
            }
          ]
        }
      }
    },
    "LabStudentPolicy": {
      "Type": "AWS::IAM::ManagedPolicy",
      "DependsOn": "LabPermissionBoundary",
      "Properties": {
        "ManagedPolicyName": "LabStudentPolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Sid": "AllowEC2FreeTierOnly",
              "Effect": "Allow",
              "Action": [
                "ec2:RunInstances",
                "ec2:StopInstances",
                "ec2:StartInstances",
                "ec2:TerminateInstances",
                "ec2:RebootInstances",
                "ec2:CreateKeyPair",
                "ec2:DeleteKeyPair",
                "ec2:ImportKeyPair",
                "ec2:CreateSecurityGroup",
                "ec2:DeleteSecurityGroup",
                "ec2:AuthorizeSecurityGroupIngress",
                "ec2:AuthorizeSecurityGroupEgress",
                "ec2:RevokeSecurityGroupIngress",
                "ec2:RevokeSecurityGroupEgress",
                "ec2:CreateTags",
                "ec2:DeleteTags"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "ec2:InstanceType": [
                    "t2.micro",
                    "t3.micro"
                  ]
                }
              }
            },
            {
              "Sid": "AllowEC2DescribeUnconditional",
              "Effect": "Allow",
              "Action": [
                "ec2:DescribeInstances",
                "ec2:DescribeInstanceStatus",
                "ec2:DescribeInstanceTypes",
                "ec2:DescribeImages",
                "ec2:DescribeKeyPairs",
                "ec2:DescribeSecurityGroups",
                "ec2:DescribeSecurityGroupRules",
                "ec2:DescribeVpcs",
                "ec2:DescribeSubnets",
                "ec2:DescribeRouteTables",
                "ec2:DescribeInternetGateways",
                "ec2:DescribeAvailabilityZones",
                "ec2:DescribeRegions",
                "ec2:DescribeTags",
                "ec2:DescribeVolumes",
                "ec2:DescribeNetworkInterfaces",
                "ec2:DescribeAddresses",
                "ec2:DescribeLaunchTemplates",
                "ec2:DescribeLaunchTemplateVersions"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowIAMRoleAndPolicyManagement",
              "Effect": "Allow",
              "Action": [
                "iam:CreateRole",
                "iam:DeleteRole",
                "iam:UpdateRole",
                "iam:PassRole",
                "iam:TagRole",
                "iam:UntagRole",
                "iam:CreatePolicy",
                "iam:DeletePolicy",
                "iam:CreatePolicyVersion",
                "iam:DeletePolicyVersion",
                "iam:SetDefaultPolicyVersion",
                "iam:AttachRolePolicy",
                "iam:DetachRolePolicy",
                "iam:PutRolePolicy",
                "iam:DeleteRolePolicy",
                "iam:CreateInstanceProfile",
                "iam:DeleteInstanceProfile",
                "iam:AddRoleToInstanceProfile",
                "iam:RemoveRoleFromInstanceProfile"
              ],
              "Resource": "*",
              "Condition": {
                "StringEquals": {
                  "iam:PermissionsBoundary": "arn:aws:iam::${AWS::AccountId}:policy/LabPermissionBoundary"
                }
              }
            },
            {
              "Sid": "AllowIAMReadAlways",
              "Effect": "Allow",
              "Action": [
                "iam:GetRole",
                "iam:ListRoles",
                "iam:GetPolicy",
                "iam:GetPolicyVersion",
                "iam:ListPolicies",
                "iam:ListPolicyVersions",
                "iam:ListEntitiesForPolicy",
                "iam:GetRolePolicy",
                "iam:ListRolePolicies",
                "iam:ListAttachedRolePolicies",
                "iam:GetInstanceProfile",
                "iam:ListInstanceProfiles",
                "iam:ListInstanceProfilesForRole",
                "iam:GetUser",
                "iam:ListUsers",
                "iam:GetGroup",
                "iam:ListGroups",
                "iam:GetUserPolicy",
                "iam:ListUserPolicies",
                "iam:ListAttachedUserPolicies",
                "iam:ListGroupsForUser",
                "iam:GetAccountSummary",
                "iam:GetAccountPasswordPolicy",
                "iam:GetCredentialReport",
                "iam:GenerateCredentialReport",
                "iam:SimulatePrincipalPolicy",
                "iam:SimulateCustomPolicy"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowSelfCredentialManagement",
              "Effect": "Allow",
              "Action": [
                "iam:ChangePassword",
                "iam:GetLoginProfile",
                "iam:UpdateLoginProfile",
                "iam:CreateAccessKey",
                "iam:DeleteAccessKey",
                "iam:ListAccessKeys",
                "iam:UpdateAccessKey",
                "iam:GetAccessKeyLastUsed"
              ],
              "Resource": "arn:aws:iam::${AWS::AccountId}:user/${LabIAMConsoleUsername}"
            },
            {
              "Sid": "DenyIAMUserAndGroupMutation",
              "Effect": "Deny",
              "Action": [
                "iam:CreateUser",
                "iam:DeleteUser",
                "iam:UpdateUser",
                "iam:CreateLoginProfile",
                "iam:DeleteLoginProfile",
                "iam:AddUserToGroup",
                "iam:RemoveUserFromGroup",
                "iam:CreateGroup",
                "iam:DeleteGroup",
                "iam:UpdateGroup",
                "iam:AttachUserPolicy",
                "iam:DetachUserPolicy",
                "iam:PutUserPolicy",
                "iam:DeleteUserPolicy",
                "iam:AttachGroupPolicy",
                "iam:DetachGroupPolicy",
                "iam:PutGroupPolicy",
                "iam:DeleteGroupPolicy"
              ],
              "Resource": "*"
            },
            {
              "Sid": "DenyBoundaryTampering",
              "Effect": "Deny",
              "Action": [
                "iam:DeleteRolePermissionsBoundary",
                "iam:DeleteUserPermissionsBoundary",
                "iam:PutRolePermissionsBoundary",
                "iam:PutUserPermissionsBoundary"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowS3LabAccess",
              "Effect": "Allow",
              "Action": [
                "s3:ListAllMyBuckets",
                "s3:GetBucketLocation",
                "s3:ListBucket",
                "s3:GetObject",
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:CreateBucket",
                "s3:DeleteBucket",
                "s3:GetBucketPolicy",
                "s3:PutBucketPolicy",
                "s3:GetBucketAcl",
                "s3:PutBucketAcl"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowCloudWatchAndLogs",
              "Effect": "Allow",
              "Action": [
                "cloudwatch:GetMetricData",
                "cloudwatch:GetMetricStatistics",
                "cloudwatch:ListMetrics",
                "cloudwatch:DescribeAlarms",
                "logs:DescribeLogGroups",
                "logs:DescribeLogStreams",
                "logs:GetLogEvents",
                "logs:FilterLogEvents"
              ],
              "Resource": "*"
            },
            {
              "Sid": "AllowSTSForRoleAssumption",
              "Effect": "Allow",
              "Action": [
                "sts:GetCallerIdentity",
                "sts:AssumeRole"
              ],
              "Resource": "*"
            },
            {
              "Sid": "DenyBillingAndOrg",
              "Effect": "Deny",
              "Action": [
                "organizations:*",
                "account:*",
                "billing:*",
                "budgets:*",
                "ce:*",
                "cur:*",
                "aws-portal:*",
                "purchase-orders:*",
                "savingsplans:*",
                "reservations:*"
              ],
              "Resource": "*"
            }
          ]
        }
      }
    },
    "LabConsoleUser": {
      "Type": "AWS::IAM::User",
      "DependsOn": [
        "LabPermissionBoundary",
        "LabStudentPolicy"
      ],
      "Properties": {
        "UserName": "LabIAMConsoleUsername",
        "LoginProfile": {
          "Password": "LabIAMConsolePassword",
          "PasswordResetRequired": false
        },
        "PermissionsBoundary": "LabPermissionBoundary",
        "ManagedPolicyArns": [
          "LabStudentPolicy"
        ]
      }
    },
    "LabIAMRole": {
      "Type": "AWS::IAM::Role",
      "DependsOn": "LabPermissionBoundary",
      "Properties": {
        "RoleName": "LabJumpVMRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ec2.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "PermissionsBoundary": "LabPermissionBoundary",
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/AmazonS3ReadOnlyAccess",
          "arn:aws:iam::aws:policy/CloudWatchAgentServerPolicy"
        ]
      }
    },
    "LabInstanceProfile": {
      "Type": "AWS::IAM::InstanceProfile",
      "Properties": {
        "InstanceProfileName": "LabJumpVMInstanceProfile",
        "Roles": [
          "LabIAMRole"
        ]
      }
    },
    "LabVPC": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "VpcCIDR",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true,
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabVPC"
          },
          {
            "Key": "CloudLabs",
            "Value": "LabUserTag"
          }
        ]
      }
    },
    "InternetGateway": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabIGW"
          },
          {
            "Key": "CloudLabs",
            "Value": "LabUserTag"
          }
        ]
      }
    },
    "AttachGateway": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": "LabVPC",
        "InternetGatewayId": "InternetGateway"
      }
    },
    "PublicSubnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": "LabVPC",
        "CidrBlock": "PublicSubnetCIDR",
        "MapPublicIpOnLaunch": true,
        "AvailabilityZone": [
          0,
          ""
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabPublicSubnet"
          },
          {
            "Key": "CloudLabs",
            "Value": "LabUserTag"
          }
        ]
      }
    },
    "PublicRouteTable": {
      "Type": "AWS::EC2::RouteTable",
      "Properties": {
        "VpcId": "LabVPC",
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabPublicRT"
          },
          {
            "Key": "CloudLabs",
            "Value": "LabUserTag"
          }
        ]
      }
    },
    "PublicRoute": {
      "Type": "AWS::EC2::Route",
      "DependsOn": "AttachGateway",
      "Properties": {
        "RouteTableId": "PublicRouteTable",
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": "InternetGateway"
      }
    },
    "SubnetRouteTableAssociation": {
      "Type": "AWS::EC2::SubnetRouteTableAssociation",
      "Properties": {
        "SubnetId": "PublicSubnet",
        "RouteTableId": "PublicRouteTable"
      }
    },
    "LabSecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "GroupDescription": "Security group for IAM Lab Windows Jump VM - allows RDP and HTTPS",
        "VpcId": "LabVPC",
        "SecurityGroupIngress": [
          {
            "IpProtocol": "tcp",
            "FromPort": 3389,
            "ToPort": 3389,
            "CidrIp": "RDPAllowedCIDR",
            "Description": "RDP access for CloudLabs EC2 over HTTP feature"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 443,
            "ToPort": 443,
            "CidrIp": "RDPAllowedCIDR",
            "Description": "HTTPS for browser-based RDP via CloudLabs"
          },
          {
            "IpProtocol": "tcp",
            "FromPort": 80,
            "ToPort": 80,
            "CidrIp": "RDPAllowedCIDR",
            "Description": "HTTP for CloudLabs EC2 access over HTTP feature"
          }
        ],
        "SecurityGroupEgress": [
          {
            "IpProtocol": "-1",
            "CidrIp": "0.0.0.0/0",
            "Description": "Allow all outbound traffic"
          }
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabSG"
          },
          {
            "Key": "CloudLabs",
            "Value": "LabUserTag"
          }
        ]
      }
    },
    "LabWindowsVM": {
      "Type": "AWS::EC2::Instance",
      "DependsOn": [
        "LabInstanceProfile",
        "LabPermissionBoundary",
        "LabConsoleUser",
        "AttachGateway"
      ],
      "CreationPolicy": {
        "ResourceSignal": {
          "Timeout": "PT20M"
        }
      },
      "Properties": {
        "IamInstanceProfile": "LabInstanceProfile",
        "ImageId": "WindowsAMIId",
        "InstanceType": "InstanceType",
        "SubnetId": "PublicSubnet",
        "SecurityGroupIds": [
          "LabSecurityGroup"
        ],
        "Tags": [
          {
            "Key": "Name",
            "Value": "IAMLabJumpVM"
          },
          {
            "Key": "CloudLabs",
            "Value": "LabUserTag"
          },
          {
            "Key": "Lab",
            "Value": "IAMBasics"
          }
        ],
        "UserData": {
          "Fn::Base64": "<powershell>\n$ErrorActionPreference = \"Stop\"\n\n# ── 1. Create / update local admin account ───────────────────────\n$Username = \"${VMAdminUsername}\"\n$Password = ConvertTo-SecureString \"${VMAdminPassword}\" -AsPlainText -Force\n\nif (Get-LocalUser -Name $Username -ErrorAction SilentlyContinue) {\n    Set-LocalUser -Name $Username -Password $Password\n} else {\n    New-LocalUser -Name $Username -Password $Password `\n        -FullName \"Lab Administrator\" `\n        -Description \"CloudLabs Jump VM admin\" `\n        -PasswordNeverExpires\n    Add-LocalGroupMember -Group \"Administrators\" -Member $Username\n}\n\n# ── 2. Enable RDP — all three keys required ──────────────────────\nSet-ItemProperty `\n    -Path \"HKLM:\\System\\CurrentControlSet\\Control\\Terminal Server\" `\n    -Name \"fDenyTSConnections\" -Value 0\n\nSet-ItemProperty `\n    -Path \"HKLM:\\System\\CurrentControlSet\\Control\\Terminal Server\\WinStations\\RDP-Tcp\" `\n    -Name \"UserAuthentication\" -Value 0\n\nSet-ItemProperty `\n    -Path \"HKLM:\\System\\CurrentControlSet\\Control\\Lsa\" `\n    -Name \"LimitBlankPasswordUse\" -Value 0\n\nEnable-NetFirewallRule -DisplayGroup \"Remote Desktop\"\n\n# ── 3. Install AWS CLI v2 ────────────────────────────────────────\ntry {\n    Invoke-WebRequest -Uri \"https://awscli.amazonaws.com/AWSCLIV2.msi\" `\n        -OutFile \"C:\\AWSCLIV2.msi\" -UseBasicParsing\n    Start-Process msiexec.exe -ArgumentList \"/i C:\\AWSCLIV2.msi /quiet /norestart\" -Wait\n    Remove-Item \"C:\\AWSCLIV2.msi\" -Force\n} catch {\n    Write-Host \"AWS CLI install failed: $_\"\n}\n\n# ── 4. Install Google Chrome ─────────────────────────────────────\ntry {\n    Invoke-WebRequest -Uri \"https://dl.google.com/chrome/install/latest/chrome_installer.exe\" `\n        -OutFile \"C:\\chrome_installer.exe\" -UseBasicParsing\n    Start-Process \"C:\\chrome_installer.exe\" -ArgumentList \"/silent /install\" -Wait\n    Remove-Item \"C:\\chrome_installer.exe\" -Force\n} catch {\n    Write-Host \"Chrome install failed: $_\"\n}\n\n# ── 5. Desktop shortcut to AWS Console ──────────────────────────\n$WshShell = New-Object -ComObject WScript.Shell\n$Shortcut = $WshShell.CreateShortcut(\"C:\\Users\\Public\\Desktop\\AWS Console.lnk\")\n$Shortcut.TargetPath  = \"C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe\"\n$Shortcut.Arguments   = \"https://${AWS::AccountId}.signin.aws.amazon.com/console\"\n$Shortcut.Description = \"Open AWS Console\"\n$Shortcut.Save()\n\n# ── 6. README on Desktop ─────────────────────────────────────────\n# NOTE: Passwords are NoEcho parameters — they cannot be written\n# here. Developers must check the CloudLabs environment page for\n# their console credentials.\n$readme = @\"\nAWS IAM Basics Lab - Contoso Startup Labs\n==========================================\n\nAWS CONSOLE LOGIN\n  URL      : https://${AWS::AccountId}.signin.aws.amazon.com/console\n  Username : ${LabIAMConsoleUsername}\n  Password : ** See your CloudLabs environment page **\n\nRDP LOGIN (this machine)\n  Username : ${VMAdminUsername}\n  Password : ** See your CloudLabs environment page **\n\nRESTRICTIONS\n  - EC2 : only t2.micro and t3.micro instance types are allowed\n  - IAM : creating users or modifying user/group policies is blocked\n  - IAM : all roles you create MUST have LabPermissionBoundary attached\n\nTOOLS PRE-INSTALLED\n  - AWS CLI v2   (open PowerShell and run: aws --version)\n  - Google Chrome\n\nFollow the lab guide shown in your CloudLabs browser tab.\n\"@\nSet-Content -Path \"C:\\Users\\Public\\Desktop\\README.txt\" -Value $readme -Encoding UTF8\n\n# ── 7. Signal CloudFormation that bootstrap completed ─────────────\n& \"C:\\Program Files\\Amazon\\cfn-bootstrap\\cfn-signal.exe\" `\n    --exit-code 0 `\n    --stack \"${AWS::StackName}\" `\n    --resource LabWindowsVM `\n    --region \"${AWS::Region}\"\n</powershell>\n<persist>true</persist>\n"
        }
      }
    }
  },
  "Outputs": {
    "LabConsoleLoginURL": {
      "Description": "AWS Console sign-in URL — shown on CloudLabs environment page",
      "Value": "https://${AWS::AccountId}.signin.aws.amazon.com/console"
    },
    "LabConsoleUsername": {
      "Description": "IAM username for AWS Console login",
      "Value": "LabIAMConsoleUsername"
    },
    "LabConsolePassword": {
      "Description": "IAM console login password — shown on CloudLabs environment page",
      "Value": "LabIAMConsolePassword"
    },
    "VMAdminUsername": {
      "Description": "Windows local admin username for RDP",
      "Value": "VMAdminUsername"
    },
    "VMAdminPassword": {
      "Description": "Windows local admin password for RDP — shown on CloudLabs environment page",
      "Value": "VMAdminPassword"
    },
    "PublicIP": {
      "Description": "Public IP address of the Windows Jump VM",
      "Value": "LabWindowsVM.PublicIp"
    },
    "InstanceId": {
      "Description": "EC2 Instance ID of the Windows Jump VM",
      "Value": "LabWindowsVM"
    },
    "VpcId": {
      "Description": "VPC ID created for this lab",
      "Value": "LabVPC"
    }
  }
}