{
 "Version": "2012-10-17",
 "Statement": [
  {
   "Effect": "Allow",
   "Principal": {
    "Service": "logs.us-east-1.amazonaws.com"
   },
   "Action": [
    "s3:PutObject",
    "s3:GetBucketAcl"
   ],
   "Resource": [
     "arn:aws:s3:::YOUR_LOG_BUCKET",
     "arn:aws:s3:::YOUR_LOG_BUCKET/*"
   ]
  }
 ]
}